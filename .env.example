# Copy this file to `.env` and fill in the provider key you want to use.
# `.env` is ignored by git. Never commit real API keys.

# ---------------------------------------------------------------------------
# Active model route
# ---------------------------------------------------------------------------
# Keep OpenAI native by setting COPILOT_MODEL_PROVIDER=openai.
# Use a low-cost OpenAI-compatible provider by setting deepseek, dashscope, or ark.
COPILOT_MODEL_PROVIDER=deepseek

# Phase-one local runs disable tracing by default so non-OpenAI providers do not
# need an OpenAI tracing key. Set false when using OpenAI and you want SDK traces.
COPILOT_TRACING_DISABLED=true

# Advanced generic overrides. Prefer provider-specific keys below for normal use.
# COPILOT_MODEL=deepseek-v4-flash
# COPILOT_API_KEY=
# COPILOT_API_KEY_ENV=DEEPSEEK_API_KEY
# COPILOT_BASE_URL=https://api.deepseek.com
# COPILOT_MODEL_TRANSPORT=chat_completions
# COPILOT_TOOL_STRATEGY=compat_functions

# ---------------------------------------------------------------------------
# Provider keys
# ---------------------------------------------------------------------------
# OpenAI native route. Best framework compatibility; usually higher cost.
# OPENAI_API_KEY=<your-openai-api-key>
# OPENAI_MODEL=gpt-5.5

# DeepSeek OpenAI-compatible route. Recommended low-cost dev default.
# DEEPSEEK_API_KEY=<your-deepseek-api-key>
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TOOL_STRATEGY=compat_functions

# Alibaba Cloud Model Studio / DashScope OpenAI-compatible route.
# DASHSCOPE_API_KEY=<your-dashscope-api-key>
# DASHSCOPE_MODEL=qwen-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volcengine Ark OpenAI-compatible route.
# Ark often uses an endpoint id or deployed model id as the model value.
# ARK_API_KEY=your-ark-api-key
# ARK_MODEL=your-ark-endpoint-or-model-id
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Any OpenAI-compatible provider not listed above.
# COPILOT_MODEL_PROVIDER=custom
# COPILOT_MODEL=provider-model-name
# COPILOT_API_KEY=provider-api-key
# COPILOT_BASE_URL=https://provider.example.com/v1

# ---------------------------------------------------------------------------
# Local API / background worker
# ---------------------------------------------------------------------------
# These settings are used by `copilot_agent.api.main:app`.
# Turn this on when you want API-created runs to be consumed automatically.
# COPILOT_API_DB_PATH=.copilot/control.sqlite
# COPILOT_API_AUTO_START_WORKER=false

# Default execution options for background-dispatched runs.
# COPILOT_WORKER_TEST_CMD=python -m pytest tests
# COPILOT_WORKER_MAX_TURNS=32
# COPILOT_WORKER_OUTPUT_DIR=runs
# COPILOT_WORKER_MEMORY_ENABLED=true
# COPILOT_WORKER_HOST_VERIFY=true
# COPILOT_WORKER_REQUIRE_API_KEY=true

# Sandbox runtime provisioning.
# COPILOT_SANDBOX_RUNTIME_ENABLED=true
# COPILOT_SANDBOX_PYTHON=python3
# COPILOT_SANDBOX_COMMAND_TIMEOUT_SECONDS=120

# Docker sandbox backend.
# Requires `pip install -e '.[docker]'` and a running Docker daemon.
# The image must contain runtime tools needed by your task, for example python, pip,
# git, pytest, node, or project-specific build tools.
# COPILOT_DOCKER_IMAGE=python:3.13-slim
# COPILOT_DOCKER_EXPOSED_PORTS=8000,5173
# COPILOT_DOCKER_NETWORK=bridge
# COPILOT_DOCKER_MEMORY_LIMIT=1g
# COPILOT_DOCKER_CPUS=2
